# ---------- Database (Neon) ----------
# Pooled connection (used by the app at runtime)
DATABASE_URL="postgresql://user:password@host.neon.tech/finops?sslmode=require&pgbouncer=true&connection_limit=1"
# Unpooled connection (used by Prisma migrations and seeds)
DIRECT_URL="postgresql://user:password@host.neon.tech/finops?sslmode=require"

# ---------- Auth (NextAuth v5 / Auth.js) ----------
AUTH_SECRET="generate with: openssl rand -base64 32"
AUTH_URL="http://localhost:3000"

# Pick one or more providers
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
# AUTH_GITHUB_ID=""
# AUTH_GITHUB_SECRET=""

# ---------- Anthropic (receipt scanning) ----------
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# ---------- Storage (Vercel Blob) ----------
# In Vercel: create a Blob store from the Storage tab; the token is auto-wired.
# For local dev, copy the token from the Vercel dashboard.
BLOB_READ_WRITE_TOKEN=""

# ---------- App ----------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_CURRENCY="NZD"
NEXT_PUBLIC_DEFAULT_LOCALE="en"
NODE_ENV="development"
